{
  "_README": "Authored, bilingual workflow library for the boss dashboard. Keyed by cron job id. 'area' links a flow to a business agent (main, procurement, accounts, sales, delivery, marketing, projects, rental, fleet, hr). The trigger pill is built from the job's real (humanized) schedule at render time; node text stays short on purpose. Node types: action, decision, message, wait, stop, done. Decision branches: exactly one has continue:true (stays on the spine); the other has terminal:{en,ar} (a dead-end outcome).",

  "py-raw-material-shortage-001": {
    "area": "procurement",
    "title": { "en": "Raw-material shortage reminder", "ar": "تنبيه نقص المواد الخام" },
    "recipients": { "en": "Javed (procurement)", "ar": "جاويد (المشتريات)" },
    "nodes": [
      { "type": "action", "en": "Check BCI raw-material stock in ERP", "ar": "فحص مخزون المواد الخام في ERP" },
      { "type": "decision", "q": { "en": "Any item short or below safety stock?", "ar": "هل يوجد صنف ناقص أو تحت حد الأمان؟" },
        "branches": [
          { "label": { "en": "No", "ar": "لا" }, "terminal": { "en": "nothing to do", "ar": "لا شيء" } },
          { "label": { "en": "Yes", "ar": "نعم" }, "continue": true } ] },
      { "type": "decision", "q": { "en": "Did Javed already open a Material Request?", "ar": "هل فتح جاويد طلب مواد بالفعل؟" },
        "branches": [
          { "label": { "en": "Yes", "ar": "نعم" }, "terminal": { "en": "stay quiet", "ar": "يبقى صامتاً" } },
          { "label": { "en": "No", "ar": "لا" }, "continue": true } ] },
      { "type": "message", "en": "WhatsApp Javed personally (+966 59 947 3704)", "ar": "مراسلة جاويد على واتساب شخصياً" },
      { "type": "wait", "en": "Next day — still no Material Request?", "ar": "اليوم التالي — لا يزال لا يوجد طلب؟" },
      { "type": "message", "en": "Send ONE follow-up", "ar": "إرسال تذكير واحد فقط" },
      { "type": "stop", "en": "Then stay silent until it reappears", "ar": "ثم يبقى صامتاً حتى تتكرر المشكلة" }
    ]
  },

